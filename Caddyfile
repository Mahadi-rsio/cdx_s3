{
    
    order static_s3 before respond
}

:8080 {
    # Matcher 1: Hashed assets (usually versioned JS/CSS/Fonts)
    @hashed_assets path *.js *.css *.woff2 *.woff *.ttf

    # Matcher 2: Everything else (HTML, favicon, metadata files)
    @revalidate_assets not path *.js *.css *.woff2 *.woff *.ttf

    # 1. Hashed JS/CSS: Cache for 1 year in browser (never check server again)
    header @hashed_assets Cache-Control "public, max-age=31536000, immutable"

    # 2. HTML & Others: Cache, but MUST validate with server on every load
    header @revalidate_assets Cache-Control "public, max-age=0, must-revalidate"

    # Matcher for media files to redirect to S3 (saves VPS bandwidth)
    @media path *.png *.jpg *.jpeg *.gif *.mp4 *.pdf *.zip *.mp3 *.ico

    handle @media {
        static_s3 {
            endpoint       http://localhost:9000
            bucket         cdx
            access_key     admin
            secret_key     StrongPassword123
            
            # Redirect media directly to S3
            redirect_to_s3   true
            presign_redirect true
            presign_lifetime 15m
        }
    }

    # Fallback handler for HTML, CSS, JS, etc. (cached locally on VPS)
    handle {
        static_s3 {
            endpoint       http://localhost:9000
            bucket         cdx
            access_key     admin
            secret_key     StrongPassword123
            
            # Serve directly from Caddy (no redirection)
            redirect_to_s3   false
            
            # Cache small site assets in memory
            cache_ttl      2m
            cache_size     1000
            max_cache_size 512KiB
        }
    }
}

